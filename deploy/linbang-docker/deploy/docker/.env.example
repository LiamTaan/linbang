# 部署根目录
DEPLOY_ROOT=/www/wwwroot/linbang-docker
UPLOAD_FILES_DIR=/www/wwwroot/linbang-docker/upload-files
LOG_DIR=/www/wwwlogs/linbang
LOG_FILE=/www/wwwlogs/linbang/yudao-server.log

# 服务器与访问入口
PUBLIC_IP=43.139.250.177
PUBLIC_PORT=8013
PUBLIC_BASE_URL=http://43.139.250.177:8013
ADMIN_UI_URL=http://43.139.250.177:8013
ADMIN_UI_HOST=43.139.250.177:8013

# 数据库
MYSQL_ROOT_PASSWORD=linbang!
MYSQL_DATABASE=linbang
MYSQL_USER=linbang
MYSQL_PASSWORD=linbang!

# Redis
REDIS_PASSWORD=linbang!
REDIS_DATABASE=1

# 后端
# 这里需要和 deploy/docker/nginx/default.conf 里的 upstream 端口保持一致
SERVER_PORT=48080
JAVA_OPTS=-Xms512m -Xmx1024m -Djava.security.egd=file:/dev/./urandom
SPRING_PROFILES_ACTIVE=prod
YUDAO_CAPTCHA_ENABLE=false

# 第三方能力
AMAP_WEB_KEY=

# 微信公众号 / 小程序
WX_MP_APP_ID=demo-wx-mp-app-id
WX_MP_SECRET=demo-wx-mp-secret
WX_MINIAPP_APPID=demo-wx-miniapp-appid
WX_MINIAPP_SECRET=demo-wx-miniapp-secret

# 社交登录，可先留空
JUSTAUTH_DINGTALK_CLIENT_ID=
JUSTAUTH_DINGTALK_CLIENT_SECRET=
JUSTAUTH_WECHAT_ENTERPRISE_CLIENT_ID=
JUSTAUTH_WECHAT_ENTERPRISE_CLIENT_SECRET=
JUSTAUTH_WECHAT_ENTERPRISE_AGENT_ID=
JUSTAUTH_ALIPAY_CLIENT_ID=
JUSTAUTH_ALIPAY_CLIENT_SECRET=
JUSTAUTH_ALIPAY_PUBLIC_KEY=

# 可选监控
DRUID_USERNAME=
DRUID_PASSWORD=
SPRING_BOOT_ADMIN_USERNAME=admin
SPRING_BOOT_ADMIN_PASSWORD=admin
